{
  "name": "@pearces/react-node-isomorphic-minimal",
  "version": "1.0.0",
  "description": "Minimal isomorphic react, node app skeleton",
  "main": "./dist/server.js",
  "browser": "./dist/bundle.js",
  "author": "Stephen Pearce (https://github.com/pearces)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pearces/react-node-isomorphic-minimal.git"
  },
  "keywords": [
    "react",
    "node",
    "express",
    "webpack",
    "redux"
  ],
  "homepage": "https://github.com/pearces/react-node-isomorphic-minimal#readme",
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-router": "^8.1.0",
    "redux": "^5.0.1",
    "webpack": "^5.108.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.7.3",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@types/react-redux": "^7.1.34",
    "concurrently": "^10.0.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-webpack": "^0.13.11",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jiti": "^2.7.0",
    "mini-css-extract-plugin": "^2.10.2",
    "nodemon": "^3.1.14",
    "normalize.css": "^8.0.1",
    "null-loader": "^4.0.1",
    "prettier": "^3.9.3",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "webpack-cli": "^7.1.0",
    "webpack-node-externals": "^3.0.0"
  },
  "scripts": {
    "build": "webpack --progress --mode production",
    "build:dev": "NODE_ENV=development webpack --progress --mode development",
    "clean": "node utils/clean.cjs dist",
    "unit": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "test": "npm run lint && npm run typecheck && npm run unit",
    "server": "NODE_ENV=production node dist/server.js",
    "server:dev": "node utils/waitForFile.cjs dist/server.js dist/manifest.json && NODE_ENV=development nodemon --inspect --delay 2.5 --watch dist --ext js --ignore dist/bundle.js dist/server.js",
    "start": "npm run clean && npm run build && npm run server",
    "start:dev": "npm run clean && concurrently \"npm:build:dev\" \"npm:server:dev\"",
    "lint": "eslint src"
  }
}
